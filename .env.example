# ── Agent demo (chatbot.py) ──────────────────────────────────────────────────
# Model to use (must be pulled via: ollama pull <model>)
OLLAMA_MODEL=llama3.1
# Ollama host — change to http://ollama:11434 when running via Docker Compose
OLLAMA_HOST=http://localhost:11434

# ── cityops-mcp server (all optional) ────────────────────────────────────────
# Path to the SQLite file. Default: platform user-data dir.
# CITYOPS_DB_PATH=/path/to/cityops.sqlite

# Directory the load_csv tool reads from. Default: <user-data-dir>/csv.
# CITYOPS_DATA_DIR=/path/to/csv

# Server log level (DEBUG, INFO, WARNING, ERROR). Default: INFO.
# CITYOPS_LOG_LEVEL=INFO
